#!/bin/bash

# image_start - 启动摄像头和二维码识别节点，并发送开始指令

set -e

# ROS环境
source /opt/ros/noetic/setup.bash

# 设置工作区路径（假设工作区在 /home/ucar/instant_ws）
WS_DIR="/home/ucar/instant_ws"
if [ -f "$WS_DIR/devel/setup.bash" ]; then
  source "$WS_DIR/devel/setup.bash"
  echo "✓ 加载工作区环境: $WS_DIR"
else
  echo "错误: 工作区环境文件不存在: $WS_DIR/devel/setup.bash"
  exit 1
fi

# 如果需要远程ROS master，请设置以下变量
# export ROS_MASTER_URI=http://192.168.1.7:11311
# export ROS_IP=192.168.1.7
# export ROS_HOSTNAME=192.168.1.7

# 检查摄像头设备
echo "检查摄像头设备..."
if [ ! -e "/dev/video0" ]; then
  echo "错误: 摄像头设备 /dev/video0 不存在！"
  echo "请检查摄像头硬件连接或驱动。"
  exit 1
else
  echo "✓ 摄像头设备 /dev/video0 存在"
fi

# 启动roscore（如果未运行）
if ! pgrep -x roscore > /dev/null; then
  echo "roscore 未运行，正在启动..."
  roscore > /tmp/image_start_roscore.log 2>&1 &
  sleep 3
  if ! pgrep -x roscore > /dev/null; then
    echo "错误: roscore 启动失败！"
    echo "查看日志: /tmp/image_start_roscore.log"
    exit 1
  fi
else
  echo "roscore 已在运行"
fi

# 启动摄像头节点
if ! rosnode list | grep -q "/ucar_camera"; then
  echo "启动摄像头节点..."
  rosrun ucar_camera ucar_camera.py > /tmp/image_start_camera.log 2>&1 &
  sleep 2
  if ! rosnode list | grep -q "/ucar_camera"; then
    echo "错误: 摄像头节点启动失败！"
    echo "查看日志: /tmp/image_start_camera.log"
    exit 1
  fi
  echo "✓ 摄像头节点启动成功"
else
  echo "摄像头节点已运行"
fi

# 检查摄像头话题
echo "检查摄像头话题..."
if ! rostopic list | grep -q "/ucar_camera/image_raw"; then
  echo "错误: 摄像头话题 /ucar_camera/image_raw 不存在！"
  echo "摄像头节点可能启动失败或设备问题。"
  exit 1
else
  echo "✓ 摄像头话题 /ucar_camera/image_raw 存在"
fi

# 启动二维码识别节点
if ! rosnode list | grep -q "/qr_code_scanner"; then
  echo "启动二维码识别节点..."
  rosrun test qr_node > /tmp/image_start_qr.log 2>&1 &
  sleep 2
  if ! rosnode list | grep -q "/qr_code_scanner"; then
    echo "错误: 二维码识别节点启动失败！"
    echo "查看日志: /tmp/image_start_qr.log"
    exit 1
  fi
  echo "✓ 二维码识别节点启动成功"
else
  echo "二维码识别节点已运行"
fi

# 发送二维码识别开始指令
echo "发送二维码识别开始指令..."
rostopic pub --once /qr_node_start std_msgs/String "data: 'start!'"

echo "启动完成。"
echo "摄像头话题: /ucar_camera/image_raw"
echo "二维码识别结果话题: /qr_code_result"
echo "二维码识别结果话题: /qr_code_result"
