<launch>
  <!-- follow_test: 基础视觉巡线 + 角点停车，不包含原 follow_end 的环岛/雷达复杂流程。 -->

  <!-- 输入图像话题。根据实际相机修改，例如 /ucar_image/image_raw 或 /ucar_camera/image_raw。 -->
  <arg name="image_topic" default="/ucar_camera/image_raw" />

  <!-- IMU 话题，用于读取 yaw，初始转角逻辑依赖它判断已经转过的角度。 -->
  <arg name="imu_topic" default="/imu" />

  <!-- 里程计话题，目前只记录位移，基础巡线控制主要不依赖它。 -->
  <arg name="odom_topic" default="/odom" />

  <!-- 底盘速度控制输出话题。 -->
  <arg name="cmd_vel_topic" default="/cmd_vel" />

  <!-- 启动/切换指令话题。发送 Left / Middle / Right / Stop。 -->
  <arg name="begin_topic" default="/follow_begin" />
  <arg name="image_queue_size" default="1" />
  <arg name="imu_queue_size" default="10" />
  <arg name="odom_queue_size" default="10" />
  <arg name="begin_queue_size" default="10" />

  <!-- 巡线完成或停车后发布结束消息的话题。 -->
  <arg name="end_topic" default="/follow_end" />
  <arg name="status_topic" default="/flow_end/follow_test_status" />
  <arg name="debug_topic" default="/flow_end/follow_test_debug" />

  <!-- 默认路径选择：left / middle / right。也可以运行中通过 begin_topic 发送指令切换。 -->
  <arg name="path_select" default="right" />
  <arg name="default_dis_bias_left" default="0.0" />
  <arg name="default_dis_bias_right" default="0.0" />
  <arg name="left_dis_bias_left" default="6.0" />
  <arg name="left_dis_bias_right" default="0.0" />
  <arg name="right_dis_bias_left" default="0.0" />
  <arg name="right_dis_bias_right" default="-30.0" />
  <arg name="middle_dis_bias_left" default="0.0" />
  <arg name="middle_dis_bias_right" default="0.0" />
  <arg name="time_local" default="0.5" />
  <arg name="left_time_local" default="0.5" />
  <arg name="right_time_local" default="0.5" />
  <arg name="middle_time_local" default="0.5" />

  <!-- 是否启用 L 型角点停车逻辑。 -->
  <arg name="parking_enabled" default="true" />

  <!-- 是否发布调试图像 /flow_end/follow_test_debug，可用 rqt_image_view 查看。 -->
  <arg name="publish_debug_image" default="true" />

  <!-- 是否弹出 OpenCV 本地窗口；远程 SSH/无桌面环境建议保持 false。 -->
  <arg name="show_window" default="false" />

  <!-- 视频保存相关参数 -->
  <!-- 是否启用视频保存（启用后将替代ROS话题发布，直接保存为AVI文件） -->
  <arg name="enable_video_record" default="true" />
  
  <!-- 视频帧率，建议10-15 FPS，过高会增加CPU和磁盘压力 -->
  <arg name="video_fps" default="10" />
  
  <!-- 视频保存路径（留空则使用默认路径 /tmp/follow_test_debug_时间戳.avi） -->
  <arg name="video_save_path" default="" />

  <!-- 正常巡线基础前进速度，转弯误差越大程序会自动降速。 -->
  <arg name="base_speed" default="0.30" />
  <arg name="aim_distance" default="0.10" />
  <arg name="aim_y_bias_m" default="0.20" />
 <!-- 最低转角速度，用于初始的巡线。 -->
  <arg name="min_pid_speed" default="0.15" />
  <arg name="y_approach_dist" default="0.20" />
  <arg name="y_turn_angle_deg" default="45.0" />
  <arg name="y_turn_angular_speed" default="0.35" />
  <arg name="y_turn_pause_sec" default="0.5" />
  <arg name="y_detect_max_id" default="10" />
  <arg name="y_detect_confirm_frames" default="3" />

  <!-- 是否启用起步预转角。Left/Right 会先原地转向目标岔路，Middle 不预转。 -->
  <arg name="initial_turn_enabled" default="true" />

  <!-- 起步预转最大角度，单位：度。达到该角度后停止预转。 -->
  <arg name="initial_turn_angle_deg" default="60" />

  <!-- 起步预转角速度，单位：rad/s。Left 为正，Right 为负。 -->
  <arg name="initial_turn_angular_speed" default="0.35" />

  <!-- 目标线点数阈值。预转过程中如果目标线点数达到该值，会提前结束预转。 -->
  <arg name="initial_turn_rpts_threshold" default="500" />

  <!-- 预转结束后的停顿时间，单位：秒。停顿期间持续发布零速度，再进入正常巡线。 -->
  <arg name="initial_turn_pause_sec" default="10" />

  <node pkg="flow_end" type="follow_test" name="follow_test" output="screen">
    <param name="image_topic" value="$(arg image_topic)" />
    <param name="imu_topic" value="$(arg imu_topic)" />
    <param name="odom_topic" value="$(arg odom_topic)" />
    <param name="cmd_vel_topic" value="$(arg cmd_vel_topic)" />
    <param name="begin_topic" value="$(arg begin_topic)" />
    <param name="image_queue_size" value="$(arg image_queue_size)" />
    <param name="imu_queue_size" value="$(arg imu_queue_size)" />
    <param name="odom_queue_size" value="$(arg odom_queue_size)" />
    <param name="begin_queue_size" value="$(arg begin_queue_size)" />
    <param name="end_topic" value="$(arg end_topic)" />
    <param name="status_topic" value="$(arg status_topic)" />
    <param name="debug_topic" value="$(arg debug_topic)" />
    <param name="path_select" value="$(arg path_select)" />
    <param name="default_dis_bias_left" value="$(arg default_dis_bias_left)" />
    <param name="default_dis_bias_right" value="$(arg default_dis_bias_right)" />
    <param name="left_dis_bias_left" value="$(arg left_dis_bias_left)" />
    <param name="left_dis_bias_right" value="$(arg left_dis_bias_right)" />
    <param name="right_dis_bias_left" value="$(arg right_dis_bias_left)" />
    <param name="right_dis_bias_right" value="$(arg right_dis_bias_right)" />
    <param name="middle_dis_bias_left" value="$(arg middle_dis_bias_left)" />
    <param name="middle_dis_bias_right" value="$(arg middle_dis_bias_right)" />
    <param name="time_local" value="$(arg time_local)" />
    <param name="left_time_local" value="$(arg left_time_local)" />
    <param name="right_time_local" value="$(arg right_time_local)" />
    <param name="middle_time_local" value="$(arg middle_time_local)" />
    <param name="parking_enabled" value="$(arg parking_enabled)" />
    <param name="publish_debug_image" value="$(arg publish_debug_image)" />
    <param name="show_window" value="$(arg show_window)" />
    <param name="enable_video_record" value="$(arg enable_video_record)" />
    <param name="video_fps" value="$(arg video_fps)" />
    <param name="video_save_path" value="$(arg video_save_path)" />
    <param name="base_speed" value="$(arg base_speed)" />
    <param name="aim_distance" value="$(arg aim_distance)" />
    <param name="aim_y_bias_m" value="$(arg aim_y_bias_m)" />
    <param name="initial_turn_enabled" value="$(arg initial_turn_enabled)" />
    <param name="initial_turn_angle_deg" value="$(arg initial_turn_angle_deg)" />
    <param name="initial_turn_angular_speed" value="$(arg initial_turn_angular_speed)" />
    <param name="initial_turn_rpts_threshold" value="$(arg initial_turn_rpts_threshold)" />
    <param name="initial_turn_pause_sec" value="$(arg initial_turn_pause_sec)" />
    <param name="min_pid_speed" value="$(arg min_pid_speed)" />
    <param name="y_approach_dist" value="$(arg y_approach_dist)" />
    <param name="y_turn_angle_deg" value="$(arg y_turn_angle_deg)" />
    <param name="y_turn_angular_speed" value="$(arg y_turn_angular_speed)" />
    <param name="y_turn_pause_sec" value="$(arg y_turn_pause_sec)" />
    <param name="y_detect_max_id" value="$(arg y_detect_max_id)" />
    <param name="y_detect_confirm_frames" value="$(arg y_detect_confirm_frames)" />
  </node>
</launch>
