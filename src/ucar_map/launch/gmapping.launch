<launch>
    <!-- 可配置参数 -->
    <arg name="scan_topic" default="scan" />  <!-- 激光雷达话题名称 -->
    <arg name="map_frame" default="map" />    <!-- 地图坐标系 -->
    <arg name="odom_frame" default="odom" />  <!-- 里程计坐标系 -->
    <arg name="base_frame" default="base_link" /> <!-- 机器人基坐标系 -->

    <!-- 启动gmapping节点 -->
    <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen" clear_params="true">
        
        <!-- 坐标系设置 -->
        <param name="map_frame" value="$(arg map_frame)"/>
        <param name="odom_frame" value="$(arg odom_frame)"/>
        <param name="base_frame" value="$(arg base_frame)"/>
        
        <!-- 核心参数 ====================================================== -->
        <param name="map_update_interval" value="3.0"/> <!-- 地图更新间隔(秒) 原5.0 -->
        <param name="maxUrange" value="4.5"/>          <!-- 有效激光范围(需小于实际最大值) -->
        <param name="maxRange" value="5.0"/>           <!-- 激光最大物理范围 -->
        <param name="delta" value="0.03"/>           <!-- 地图分辨率(m) 原0.05 -->
        
        <!-- 扫描匹配参数 ================================================== -->
        <param name="sigma" value="0.03"/>            <!-- 扫描匹配标准差 原0.05 -->
        <param name="kernelSize" value="1"/>           <!-- 匹配核大小 -->
        <param name="lstep" value="0.02"/>             <!-- 平移优化步长(m) 原0.05 -->
        <param name="astep" value="0.02"/>             <!-- 旋转优化步长(rad) 原0.05 -->
        <param name="iterations" value="10"/>           <!-- 优化迭代次数 原5 -->
        <param name="lsigma" value="0.05"/>            <!-- 似然场标准差 原0.075 -->
        <param name="ogain" value="2.0"/>              <!-- 障碍物增益 原3.0 -->
        <param name="lskip" value="0"/>                <!-- 跳过的激光束数(0=不跳过) -->
        
        <!-- 运动模型噪声参数 ============================================== -->
        <param name="srr" value="0.005"/>              <!-- 旋转-旋转噪声 原0.01 -->
        <param name="srt" value="0.01"/>               <!-- 平移-旋转噪声 原0.02 -->
        <param name="str" value="0.005"/>              <!-- 旋转-平移噪声 原0.01 -->
        <param name="stt" value="0.01"/>              <!-- 平移-平移噪声 原0.02 -->
        
        <!-- 更新触发条件 ================================================== -->
        <param name="linearUpdate" value="0.2"/>       <!-- 平移运动触发距离(m) 原0.5 -->
        <param name="angularUpdate" value="0.2"/>       <!-- 旋转运动触发角度(rad) 原0.436 -->
        <param name="temporalUpdate" value="2.0"/>      <!-- 时间触发更新(秒) 原-1.0 -->
        
        <!-- 粒子滤波参数 ================================================= -->
        <param name="particles" value="120"/>           <!-- 粒子数 原80 -->
        <param name="resampleThreshold" value="0.4"/>   <!-- 重采样阈值 原0.5 -->
        
        <!-- 采样器参数 =================================================== -->
        <param name="llsamplerange" value="0.01"/>      <!-- 平移采样范围 -->
        <param name="llsamplestep" value="0.01"/>       <!-- 平移采样步长 -->
        <param name="lasamplerange" value="0.005"/>     <!-- 旋转采样范围 -->
        <param name="lasamplestep" value="0.005"/>     <!-- 旋转采样步长 -->
        
        <!-- 初始地图尺寸 ================================================== -->
        <param name="xmin" value="-10.0"/>             <!-- 初始地图X最小值(m) 原-1.0 -->
        <param name="ymin" value="-10.0"/>             <!-- 初始地图Y最小值(m) 原-1.0 -->
        <param name="xmax" value="10.0"/>              <!-- 初始地图X最大值(m) 原1.0 -->
        <param name="ymax" value="10.0"/>              <!-- 初始地图Y最大值(m) 原1.0 -->
        
        <!-- 话题重映射 -->
        <remap from="scan" to="$(arg scan_topic)"/>
    </node>
</launch>